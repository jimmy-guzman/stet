{
  "name": "stet-monorepo",
  "private": true,
  "license": "MIT",
  "repository": "github:jimmy-guzman/stet",
  "workspaces": [
    "packages/*",
    "docs"
  ],
  "type": "module",
  "scripts": {
    "build": "bun run --cwd packages/tui build",
    "build:dist": "bun run --cwd packages/tui build:dist",
    "check": "bun run --cwd packages/tui check && bun run knip",
    "docs:build": "bun run --cwd docs build",
    "docs:check": "bun run gen:keys --check && bun run --cwd docs check",
    "docs:dev": "bun run --cwd docs dev",
    "gen:keys": "bun run --cwd packages/tui gen:keys",
    "knip": "knip",
    "prepare": "effect-language-service patch",
    "screenshots": "bun run --cwd packages/tui screenshots",
    "stet": "bun run --cwd packages/tui stet",
    "test": "bun run --cwd packages/tui test"
  },
  "devDependencies": {
    "@effect/language-service": "0.86.4",
    "knip": "6.25.0",
    "lefthook": "2.1.9",
    "oxfmt": "0.58.0",
    "oxlint": "1.73.0",
    "oxlint-tsgolint": "0.24.0"
  }
}
